GGRAVATED                |HOTEL/MOTEL                           |false |false   |0122|001     |42  |32            |02      |NULL        |NULL        |2017|02/11/2018 03:57:41 PM|NULL        |NULL         |NULL                         |\n|13203321|JG415333   |09/06/2023 05:00:00 PM|002XX N Wells st       |1320|CRIMINAL DAMAGE           |TO VEHICLE                    |PARKING LOT / GARAGE (NON RESIDENTIAL)|false |false   |0122|001     |42  |32            |14      |1174694     |1901831     |2023|11/04/2023 03:40:18 PM|41.886018055|-87.633937881|(41.886018055, -87.633937881)|\n+--------+-----------+----------------------+-----------------------+----+--------------------------+------------------------------+--------------------------------------+------+--------+----+--------+----+--------------+--------+------------+------------+----+----------------------+------------+-------------+-----------------------------+\nonly showing top 5 rows\nval \u001b[1m\u001b[34mRUTA\u001b[0m: \u001b[1m\u001b[32mString\u001b[0m = /data/crimenes.csv\nval \u001b[1m\u001b[34mdfRaw\u001b[0m: \u001b[1m\u001b[32morg.apache.spark.sql.classic.DataFrame\u001b[0m = [ID: string, Case Number: string ... 20 more fields]\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=0"},{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=1"},{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=2"},{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=3"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784479913189_183477679","id":"paragraph_1784479913189_183477679","dateCreated":"2026-07-19T16:51:53+0000","dateStarted":"2026-07-19T17:21:31+0000","dateFinished":"2026-07-19T17:22:01+0000","status":"FINISHED"},{"text":"%md\n### Limpieza y casteo de tipos","user":"anonymous","dateUpdated":"2026-07-19T17:04:16+0000","progress":0,"config":{"tableHide":false,"editorSetting":{"params":{},"forms":{},"language":"markdown","editOnDblClick":true,"completionKey":"TAB","completionSupport":false},"colWidth":12,"fontSize":9,"editorHide":true,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<div class=\"markdown-body\">\n<h3>Limpieza y casteo de tipos</h3>\n\n</div>"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784480647801_1959893228","id":"paragraph_1784480647801_1959893228","dateCreated":"2026-07-19T17:04:07+0000","dateStarted":"2026-07-19T17:04:16+0000","dateFinished":"2026-07-19T17:04:16+0000","status":"FINISHED"},{"text":"%spark\nimport org.apache.spark.sql.types._\nimport org.apache.spark.sql.functions._\n\nvar dfClean = dfRaw\n  .withColumn(\"Latitude\", col(\"Latitude\").cast(\"double\"))\n  .withColumn(\"Longitude\", col(\"Longitude\").cast(\"double\"))\n  .withColumn(\"Arrest\", col(\"Arrest\").cast(\"boolean\"))\n  .withColumn(\"Domestic\", col(\"Domestic\").cast(\"boolean\"))\n  .withColumn(\"Date_TS\", to_timestamp(col(\"Date\"), \"MM/dd/yyyy hh:mm:ss a\"))\n  .withColumn(\"Year\", col(\"Year\").cast(\"int\"))\n\n// Quitar nulos y coordenadas fantasma (0.0)\ndfClean = dfClean.filter(col(\"Latitude\").isNotNull && col(\"Latitude\") =!= 0.0)\n\n// Crear vista para usar SQL en los siguientes pasos\ndfClean.createOrReplaceTempView(\"crimes\")\nprintln(\"Limpieza terminada. Vista 'crimes' registrada.\")","user":"anonymous","dateUpdated":"2026-07-19T17:22:04+0000","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"params":{},"forms":{},"language":"scala","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Limpieza terminada. Vista 'crimes' registrada.\nimport org.apache.spark.sql.types._\nimport org.apache.spark.sql.functions._\nvar \u001b[1m\u001b[34mdfClean\u001b[0m: \u001b[1m\u001b[32morg.apache.spark.sql.classic.DataFrame\u001b[0m = [ID: string, Case Number: string ... 21 more fields]\n// mutated dfClean\n"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784479893632_1401823607","id":"paragraph_1784479893632_1401823607","dateCreated":"2026-07-19T16:51:33+0000","dateStarted":"2026-07-19T17:22:04+0000","dateFinished":"2026-07-19T17:22:05+0000","status":"FINISHED"},{"text":"%md\nEDA univariado","user":"anonymous","dateUpdated":"2026-07-19T17:04:39+0000","progress":0,"config":{"tableHide":false,"editorSetting":{"params":{},"forms":{},"language":"markdown","editOnDblClick":true,"completionKey":"TAB","completionSupport":false},"colWidth":12,"fontSize":9,"editorHide":true,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<div class=\"markdown-body\">\n<p>EDA univariado</p>\n\n</div>"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784480668440_2048084333","id":"paragraph_1784480668440_2048084333","dateCreated":"2026-07-19T17:04:28+0000","dateStarted":"2026-07-19T17:04:39+0000","dateFinished":"2026-07-19T17:04:39+0000","status":"FINISHED"},{"text":"%sql\nSELECT `Primary Type`, COUNT(1) AS Total\nFROM crimes\nGROUP BY `Primary Type`\nORDER BY Total DESC\nLIMIT 15","user":"anonymous","dateUpdated":"2026-07-19T16:58:24+0000","progress":81,"config":{"colWidth":12,"fontSize":9,"results":{"0":{"graph":{"mode":"pieChart","height":300,"optionOpen":false,"setting":{},"keys":[{"name":"Primary Type","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"Total","index":1,"aggr":"sum"}],"commonSetting":{}}}},"enabled":true,"editorSetting":{"params":{},"forms":{},"language":"sql","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TABLE","data":"Primary Type\tTotal\nTHEFT\t1804387\nB