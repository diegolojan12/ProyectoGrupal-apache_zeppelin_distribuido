16:58:29+0000","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"0":{"graph":{"mode":"pieChart","height":300,"optionOpen":false,"setting":{},"keys":[{"name":"Primary Type","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"Total_Incidentes","index":1,"aggr":"sum"}],"commonSetting":{}}}},"enabled":true,"editorSetting":{"params":{},"forms":{},"language":"sql","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TABLE","data":"Primary Type\tTotal_Incidentes\tPorcentaje_Arresto\nPROSTITUTION\t69847\t99.55\nNARCOTICS\t755597\t99.35\nGAMBLING\t14575\t99.33\nLIQUOR LAW VIOLATION\t15383\t99.02\nINTERFERENCE WITH PUBLIC OFFICER\t20848\t91.83\nWEAPONS VIOLATION\t127816\t72.81\nCRIMINAL TRESPASS\t229588\t67.32\nPUBLIC PEACE VIOLATION\t55406\t62.41\nHOMICIDE\t14310\t48.39\nSEX OFFENSE\t33102\t25.55\nBATTERY\t1559094\t21.64\nASSAULT\t576967\t20.06\nOFFENSE INVOLVING CHILDREN\t57143\t19.00\nOTHER OFFENSE\t532214\t17.72\nCRIM SEXUAL ASSAULT\t25748\t15.83\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=22"},{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=23"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784480066943_1037817119","id":"paragraph_1784480066943_1037817119","dateCreated":"2026-07-19T16:54:26+0000","dateStarted":"2026-07-19T16:54:37+0000","dateFinished":"2026-07-19T16:54:48+0000","status":"FINISHED"},{"text":"%md\n### Heatmap\n","user":"anonymous","dateUpdated":"2026-07-19T17:05:36+0000","progress":0,"config":{"tableHide":false,"editorSetting":{"params":{},"forms":{},"language":"markdown","editOnDblClick":true,"completionKey":"TAB","completionSupport":false},"colWidth":12,"fontSize":9,"editorHide":true,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<div class=\"markdown-body\">\n<h3>Heatmap</h3>\n\n</div>"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784480722374_259856156","id":"paragraph_1784480722374_259856156","dateCreated":"2026-07-19T17:05:22+0000","dateStarted":"2026-07-19T17:05:36+0000","dateFinished":"2026-07-19T17:05:36+0000","status":"FINISHED"},{"text":"%spark\nval dfTemporal = dfClean.filter(col(\"Date_TS\").isNotNull)\n  .withColumn(\"Dia_Semana\", date_format(col(\"Date_TS\"), \"EEEE\"))\n  .withColumn(\"Hora_Dia\", hour(col(\"Date_TS\")))\n\nval agrupadoTiempo = dfTemporal.groupBy(\"Dia_Semana\", \"Hora_Dia\").count()\nagrupadoTiempo.createOrReplaceTempView(\"crimenes_heatmap\")\n\nspark.table(\"crimenes_heatmap\").show(5)","user":"anonymous","dateUpdated":"2026-07-19T17:22:11+0000","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"params":{},"forms":{},"language":"scala","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"+----------+--------+-----+\n|Dia_Semana|Hora_Dia|count|\n+----------+--------+-----+\n|    Sunday|       1|55241|\n|  Thursday|       7|31124|\n|    Sunday|      19|62642|\n|    Monday|       8|45628|\n| Wednesday|       6|20555|\n+----------+--------+-----+\nonly showing top 5 rows\nval \u001b[1m\u001b[34mdfTemporal\u001b[0m: \u001b[1m\u001b[32morg.apache.spark.sql.classic.DataFrame\u001b[0m = [ID: string, Case Number: string ... 23 more fields]\nval \u001b[1m\u001b[34magrupadoTiempo\u001b[0m: \u001b[1m\u001b[32morg.apache.spark.sql.classic.DataFrame\u001b[0m = [Dia_Semana: string, Hora_Dia: int ... 1 more field]\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=4"},{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=5"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784480092358_1848233163","id":"paragraph_1784480092358_1848233163","dateCreated":"2026-07-19T16:54:52+0000","dateStarted":"2026-07-19T17:22:11+0000","dateFinished":"2026-07-19T17:22:30+0000","status":"FINISHED"},{"text":"%pyspark\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nimport pandas as pd\n\ndf_pd = spark.table(\"crimenes_heatmap\").toPandas()\n\ndias_orden = [\"Monday\", \"Tuesday\", \"Wednesday\", \"Thursday\", \"Friday\", \"Saturday\", \"Sunday\"]\ndf_pd['Dia_Semana'] = pd.Categorical(df_pd['Dia_Semana'], categories=dias_orden, ordered=True)\nmatriz_calor = df_pd.pivot(index=\"Dia_Semana\", columns=\"Hora_Dia\", values=\"count\")\n\nplt.figure(figsize=(12, 5))\nsns.heatmap(matriz_calor, cmap=\"YlOrRd\", linewidths=.5)\nplt.title(\"Mapa de Calor: Crímenes por Día y Hora\")\nplt.xlabel(\"Hora del Día (0-23)\")\nplt.ylabel(\"Día de la Semana\")\nplt.tight_layout()\n\nz.show(plt, width='100%')","user":"anonymous","dateUpdated":"2026-07-19T17:22:32+0000","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"params":{},"forms":{},"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<div style='width:100%;height:auto'><img src=data:image/png;base64, style='width=100%;height:auto'><div>\n"},{"type":"HTML","data":"<div style='width:auto;height:auto'><img src=data:image/png;base64, style='width=auto;height:auto'><div>\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=6"},{"jobUrl":"http://172.29.113.169:4040/jobs/job?id=7"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784481265798_970815528","id":"paragraph_1784481265798_970815528","dateCreated":"2026-07-19T17:14:25+0000","dateStarted":"2026-07-19T17:22:32+0000","dateFinished":"2026-07-19T17:22:52+0000","status":"FINISHED"},{"text":"%md\n### Eficiencia por Distrito","user":"anonymous","dateUpdated":"2026-07-19T17:07:31+0000","progress":0,"config":{"tableHide":false,"editorSetting":{"params":{},"forms":{},"language":"markdown","editOnDblClick":true,"completionKey":"TAB","completionSupport":false},"colWidth":12,"fontSize":9,"editorHide":true,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<div class=\"markdown-body\">\n<h3>Eficiencia por Distrito</h3>\n\n</div>"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1784480846218_1824933849","id":"paragraph_1784480846218_1824933849","dateCreated":"2026-07-19T17:07:26+0000","dateStarted":"2026-07-19T17:07:31+0000","dateFinished":"2026-07-19T17:07:31+0000","status":"FINISHED"},{"text":"%spark\nval indiceDistrito = dfClean.filter(col(\"District\").isNotNull)\n  .groupBy(\"District\")\n  .agg(\n    count(\"*\").alias(\"Total_Incidentes\"),\n    sum(when(col(\"Arrest\") === true, 1).otherwise(0)).alias(\"Arrestos_Logrados\")\n  )\n  .withColumn(\"Eficiencia_Pct\", round((col(\"Arrestos_Logrados\") / col(\"Total_Incidentes\")) * 100, 2))\n\n// Mostrar solo distritos con más de 10,000 incidentes para que sea estadísticamente válido\nindiceDistrito.filter(col(\"Total_Incidentes\") >= 10000)\n  .orderBy(desc(\"Eficiencia_Pct\"))\n  .show(10, false)","user":"anonymous","dateUpdated":"2026-07-19T16:55:55+0000","progress":87,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"params":{},"forms":{},"language":"scala","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"+--------+----------------+----------------